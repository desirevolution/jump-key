{
    debug
    auto_https off
    order webdav before file_server

    log {
        output stdout
        format json
        level DEBUG
    }
}

:80 {
    # Aktiviert HTTP-Access-Logs
    log {
        output stdout
        format json
        level DEBUG
    }

    # Zusätzliche, deutlich sichtbare Access-Log-Felder
    log_append <remote_user "{http.request.header.Remote-User}"
    log_append <requested_uri "{http.request.uri}"
    log_append <request_method "{http.request.method}"

    root * /app

    route /config/* {
        header Cache-Control "no-store, no-cache, must-revalidate" defer

        @user_config {
            path /config/services.json
            header Remote-User ?*
        }
        rewrite @user_config /config/services.{http.request.header.Remote-User}.json

        @user_backup {
            path_regexp backup ^/config/services\.backup-(.+)\.json$
            header Remote-User ?*
        }
        rewrite @user_backup /config/services.{http.request.header.Remote-User}.backup-{re.backup.1}.json

        @forbidden_methods {
            method DELETE PROPFIND PROPPATCH MKCOL COPY MOVE LOCK UNLOCK
        }
        respond @forbidden_methods "Method Not Allowed" 405

        @is_put method PUT
        webdav @is_put {
            root /app
        }

        file_server
    }

    route {
        try_files {path} {path}/ /index.html
        file_server
    }
}
