{
    debug
    auto_https off
    order webdav before file_server

    log {
        output stdout
        format json
        level INFO
    }
}

:80 {
    root * /app

    route /config/* {
        header Cache-Control "no-store, no-cache, must-revalidate" defer

        # 1. Matcher: Prüft, ob der Header "Remote-User" gesetzt ist
        @user_config {
            path /config/services.json
            header Remote-User ?*
        }
        # Liest exakt den Header aus deinem Log "arthur" -> /config/services.arthur.json
        rewrite @user_config /config/services.{http.request.header.Remote-User}.json

        # 2. Backup-Matcher
        @user_backup {
            path_regexp backup ^/config/services\.backup-(.+)\.json$
            header Remote-User ?*
        }
        rewrite @user_backup /config/services.{http.request.header.Remote-User}.backup-{re.backup.1}.json

        # 3. WebDAV: Nur PUT erlauben, alles andere an WebDAV blockieren
        @forbidden_methods {
            method DELETE PROPFIND PROPPATCH MKCOL COPY MOVE LOCK UNLOCK
        }
        respond @forbidden_methods "Method Not Allowed" 405

        @is_put {
            method PUT
        }
        webdav @is_put {
            root /app
        }

        # 4. Lese-Zugriff für GET
        file_server
    }

    # SPA Fallback
    route {
        try_files {path} {path}/ /index.html
        file_server
    }
}
